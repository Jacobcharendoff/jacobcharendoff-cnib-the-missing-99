diff --git a/src/components/ParallaxSection.tsx b/src/components/ParallaxSection.tsx
new file mode 100644
index 0000000..2fae540
--- /dev/null
+++ b/src/components/ParallaxSection.tsx
@@ -0,0 +1,36 @@
+"use client";
+
+import { useRef, type ReactNode } from "react";
+import { motion, useScroll, useTransform, useReducedMotion } from "framer-motion";
+
+interface ParallaxSectionProps {
+  children: ReactNode;
+  className?: string;
+  offset?: number;
+}
+
+export default function ParallaxSection({
+  children,
+  className,
+  offset = 60,
+}: ParallaxSectionProps) {
+  const ref = useRef<HTMLDivElement>(null);
+  const prefersReducedMotion = useReducedMotion();
+
+  const { scrollYProgress } = useScroll({
+    target: ref,
+    offset: ["start end", "end start"],
+  });
+
+  const y = useTransform(
+    scrollYProgress,
+    [0, 1],
+    prefersReducedMotion ? [0, 0] : [offset, -offset]
+  );
+
+  return (
+    <div ref={ref} className={className}>
+      <motion.div style={{ y, willChange: "transform" }}>{children}</motion.div>
+    </div>
+  );
+}
diff --git a/src/components/ToolkitFilter.tsx b/src/components/ToolkitFilter.tsx
new file mode 100644
index 0000000..c82cc1f
--- /dev/null
+++ b/src/components/ToolkitFilter.tsx
@@ -0,0 +1,115 @@
+"use client";
+
+import { useState, useMemo } from "react";
+import Link from "next/link";
+import { motion, AnimatePresence } from "framer-motion";
+
+interface Resource {
+  id: string;
+  title: string;
+  description: string;
+  type: "worksheet" | "guide" | "template" | "podcast";
+  format: string;
+  fileName: string;
+  downloadUrl: string;
+  relatedModule?: string;
+}
+
+const typeLabels: Record<string, string> = {
+  all: "All",
+  worksheet: "Worksheets",
+  guide: "Guides",
+  template: "Templates",
+  podcast: "Podcasts",
+};
+
+export default function ToolkitFilter({ resources }: { resources: Resource[] }) {
+  const [active, setActive] = useState<string>("all");
+
+  const filters = useMemo(() => {
+    const present = new Set<string>(resources.map((r) => r.type));
+    return ["all", ...["worksheet", "guide", "template", "podcast"].filter((t) =>
+      present.has(t as Resource["type"])
+    )];
+  }, [resources]);
+
+  const visible =
+    active === "all" ? resources : resources.filter((r) => r.type === active);
+
+  return (
+    <>
+      <div
+        className="flex flex-wrap gap-2 mb-10"
+        role="tablist"
+        aria-label="Filter resources by type"
+      >
+        {filters.map((f) => (
+          <button
+            key={f}
+            className="filter-pill"
+            data-active={active === f ? "true" : "false"}
+            onClick={() => setActive(f)}
+            role="tab"
+            aria-selected={active === f}
+            aria-controls="filtered-resources"
+          >
+            {typeLabels[f]}
+          </button>
+        ))}
+      </div>
+
+      <motion.div
+        id="filtered-resources"
+        className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
+        layout
+      >
+        <AnimatePresence mode="popLayout">
+          {visible.map((resource) => (
+            <motion.div
+              key={resource.id}
+              layout
+              initial={{ opacity: 0, y: 16 }}
+              animate={{ opacity: 1, y: 0 }}
+              exit={{ opacity: 0, y: -8, scale: 0.96 }}
+              transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1] }}
+              className="premium-card flex flex-col group"
+            >
+              <div className="flex items-center gap-3 mb-5">
+                <span className="badge">
+                  {typeLabels[resource.type].replace(/s$/, "")}
+                </span>
+                <span className="text-xs text-text-muted font-medium">
+                  {resource.format}
+                </span>
+              </div>
+              <h3 className="text-lg font-bold text-cnib-black mb-3 transition-colors group-hover:text-cnib-blue">
+                {resource.title}
+              </h3>
+              <p className="text-sm text-text-secondary leading-relaxed mb-6 flex-1">
+                {resource.description}
+              </p>
+              <div className="flex items-center gap-4">
+                <a
+                  href={resource.downloadUrl}
+                  download={resource.fileName}
+                  className="btn-primary text-sm py-2.5 px-6"
+                  aria-label={`Download ${resource.title} (${resource.format})`}
+                >
+                  Download
+                </a>
+                {resource.relatedModule && (
+                  <Link
+                    href={`/themes/${resource.relatedModule}`}
+                    className="text-sm text-cnib-blue hover:text-cnib-black focus-visible:text-cnib-black no-underline transition-colors font-medium"
+                  >
+                    View module <span aria-hidden="true">&rarr;</span>
+                  </Link>
+                )}
+              </div>
+            </motion.div>
+          ))}
+        </AnimatePresence>
+      </motion.div>
+    </>
+  );
+}
