@@ -0,0 +1,75 @@
+"use client";
+
+import { useRef, useState, type ReactNode, type CSSProperties } from "react";
+import { motion, useReducedMotion } from "framer-motion";
+
+interface SpotlightCardProps {
+  children: ReactNode;
+  className?: string;
+  /** Tailwind / CSS size of the spotlight circle. Default 420px. */
+  spotlightSize?: number;
+  /** RGBA color string inside rgba(...) for the spotlight. */
+  spotlightColor?: string;
+}
+
+/**
+ * Aceternity-style spotlight card: a radial gradient follows the
+ * cursor inside the card boundary. Reimplemented from scratch —
+ * no external package — using local mouse tracking + a motion.div
+ * overlay that animates its position via CSS custom properties.
+ *
+ * Wraps existing .glass-card styling. The spotlight renders as a
+ * pseudo-layer; card content sits above via z-index.
+ */
+export default function SpotlightCard({
+  children,
+  className = "",
+  spotlightSize = 420,
+  spotlightColor = "rgba(212, 165, 116, 0.22)",
+}: SpotlightCardProps) {
+  const ref = useRef<HTMLDivElement>(null);
+  const [pos, setPos] = useState<{ x: number; y: number } | null>(null);
+  const [opacity, setOpacity] = useState(0);
+  const reducedMotion = useReducedMotion();
+
+  const handleMove = (e: React.MouseEvent<HTMLDivElement>) => {
+    if (reducedMotion) return;
+    const el = ref.current;
+    if (!el) return;
+    const rect = el.getBoundingClientRect();
+    setPos({ x: e.clientX - rect.left, y: e.clientY - rect.top });
+  };
+
+  return (
+    <div
+      ref={ref}
+      onMouseMove={handleMove}
+      onMouseEnter={() => !reducedMotion && setOpacity(1)}
+      onMouseLeave={() => setOpacity(0)}
+      onFocus={() => !reducedMotion && setOpacity(1)}
+      onBlur={() => setOpacity(0)}
+      className={`glass-card relative group block h-full ${className}`}
+      style={
+        {
+          "--spot-size": `${spotlightSize}px`,
+          "--spot-color": spotlightColor,
+        } as CSSProperties
+      }
+    >
+      {/* Spotlight layer — sits between card bg and content */}
+      <motion.div
+        aria-hidden="true"
+        className="pointer-events-none absolute inset-0 rounded-[inherit]"
+        style={{
+          background: pos
+            ? `radial-gradient(var(--spot-size) circle at ${pos.x}px ${pos.y}px, var(--spot-color), transparent 70%)`
+            : "transparent",
+          zIndex: 0,
+        }}
+        animate={{ opacity }}
+        transition={{ duration: 0.3, ease: [0.16, 1, 0.3, 1] }}
+      />
+      <div className="relative z-[1]">{children}</div>
+    </div>
+  );
+}
