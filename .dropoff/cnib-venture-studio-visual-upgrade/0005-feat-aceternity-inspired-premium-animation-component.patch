+"use client";
+
+import { motion, useReducedMotion } from "framer-motion";
+import type { ReactNode } from "react";
+
+interface TextGenerateProps {
+  /** The text to animate. Will be split on whitespace. */
+  words: string;
+  /** Per-word delay in seconds. */
+  stagger?: number;
+  /** Optional highlight class applied to specific words (by index). */
+  highlightIndices?: Record<number, string>;
+  className?: string;
+  as?: "h1" | "h2" | "h3" | "p" | "span";
+  /** Extra children rendered after the animated words (e.g. punctuation). */
+  trailing?: ReactNode;
+}
+
+/**
+ * Aceternity-style "text generate effect" — each word appears with a
+ * blur-to-sharp fade, staggered. Reimplemented here with framer-motion.
+ * Respects prefers-reduced-motion (resolves instantly to final state
+ * via MotionConfig reducedMotion="user" in Providers.tsx, plus an
+ * explicit fallback variant here).
+ *
+ * We split on whitespace (not characters) — whole-word motion feels
+ * premium; per-letter feels jittery at this size.
+ */
+export default function TextGenerate({
+  words,
+  stagger = 0.08,
+  highlightIndices = {},
+  className = "",
+  as: Tag = "h1",
+  trailing,
+}: TextGenerateProps) {
+  const reducedMotion = useReducedMotion();
+  const tokens = words.split(/(\s+)/); // keep whitespace tokens
+
+  let wordCount = -1;
+
+  return (
+    <Tag className={className}>
+      <span className="sr-only">{words}</span>
+      <span aria-hidden="true">
+        {tokens.map((tok, i) => {
+          if (/^\s+$/.test(tok)) {
+            return <span key={i}>{tok}</span>;
+          }
+          wordCount += 1;
+          const highlight = highlightIndices[wordCount];
+          const idx = wordCount;
+          return (
+            <motion.span
+              key={i}
+              className={`inline-block ${highlight ?? ""}`}
+              initial={
+                reducedMotion
+                  ? { opacity: 1, filter: "blur(0px)", y: 0 }
+                  : { opacity: 0, filter: "blur(10px)", y: 8 }
+              }
+              whileInView={{ opacity: 1, filter: "blur(0px)", y: 0 }}
+              viewport={{ once: true, margin: "-80px" }}
+              transition={{
+                duration: 0.7,
+                delay: idx * stagger,
+                ease: [0.16, 1, 0.3, 1],
+              }}
+            >
+              {tok}
+            </motion.span>
+          );
+        })}
+        {trailing}
+      </span>
+    </Tag>
+  );
+}
