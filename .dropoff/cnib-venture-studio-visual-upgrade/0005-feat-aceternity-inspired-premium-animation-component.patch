+++ b/src/components/BackgroundBeams.tsx
@@ -0,0 +1,83 @@
+"use client";
+
+import { motion, useReducedMotion } from "framer-motion";
+import { useId } from "react";
+
+/**
+ * Aceternity-style background beams, reimplemented with framer-motion.
+ * Renders a set of diagonal SVG paths whose stroke-dashoffset travels
+ * from 0 → length, producing a subtle "beams of light" sweep behind
+ * the hero content. Intentionally low-opacity so it complements the
+ * iris rings in HeroVisual rather than competing with them.
+ *
+ * Fully decorative — aria-hidden. Freezes to a static frame under
+ * prefers-reduced-motion (motion config reduces duration globally,
+ * but we explicitly bail on the animate prop to be safe).
+ */
+export default function BackgroundBeams() {
+  const gradId = useId();
+  const reducedMotion = useReducedMotion();
+
+  // Six subtly different paths — all vaguely diagonal, staggered.
+  const paths = [
+    "M-200 -180 C 120 60, 320 220, 900 420",
+    "M-140 -60 C 180 160, 420 280, 960 520",
+    "M-240 40 C 140 240, 460 380, 1020 560",
+    "M-80 120 C 220 300, 560 440, 1080 640",
+    "M-320 240 C 160 380, 520 520, 1120 700",
+    "M-60 360 C 240 480, 620 600, 1160 820",
+  ];
+
+  return (
+    <div
+      aria-hidden="true"
+      className="absolute inset-0 pointer-events-none overflow-hidden"
+    >
+      <svg
+        className="absolute inset-0 w-full h-full"
+        viewBox="0 0 1000 800"
+        preserveAspectRatio="xMidYMid slice"
+        fill="none"
+      >
+        <defs>
+          <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
+            <stop offset="0%" stopColor="#D4A574" stopOpacity="0" />
+            <stop offset="40%" stopColor="#D4A574" stopOpacity="0.55" />
+            <stop offset="60%" stopColor="#E8C49A" stopOpacity="0.7" />
+            <stop offset="100%" stopColor="#D4A574" stopOpacity="0" />
+          </linearGradient>
+        </defs>
+
+        {paths.map((d, i) => (
+          <motion.path
+            key={i}
+            d={d}
+            stroke={`url(#${gradId})`}
+            strokeWidth={1.2}
+            strokeLinecap="round"
+            initial={{ pathLength: 0, opacity: 0 }}
+            animate={
+              reducedMotion
+                ? { pathLength: 1, opacity: 0.5 }
+                : {
+                    pathLength: [0, 1, 1],
+                    opacity: [0, 0.65, 0],
+                  }
+            }
+            transition={
+              reducedMotion
+                ? { duration: 0 }
+                : {
+                    duration: 6 + i * 0.4,
+                    repeat: Infinity,
+                    repeatDelay: 1.5,
+                    delay: i * 0.8,
+                    ease: "easeInOut",
+                  }
+            }
+          />
+        ))}
+      </svg>
+    </div>
+  );
+}
